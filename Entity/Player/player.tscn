[sub_resource type="GDScript" id="GDScript_viyt1"]
resource_name = "PlayerAnimation"
script/source = "extends AnimatedSprite2D
class_name PlayerAnimation

@export var player: CharacterBody2D

var _player_state: PlayerStateResource.States = PlayerStateResource.States.IDLE

func _ready() -> void:
	assert(player is CharacterBody2D)

func _process(_delta: float) -> void:
	if player.velocity.x:
		flip_h = player.velocity.x < 0.0
	
	if _player_state == PlayerStateResource.States.IDLE:
		play(\"idle\")
"

