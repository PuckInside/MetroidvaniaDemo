[sub_resource type="GDScript" id="GDScript_x1f5c"]
resource_name = "PlayerAnimations"
script/source = "extends AnimatedSprite2D

@export var player: PlayerController

func _ready() -> void:
	assert(player is PlayerController)

func _process(_delta: float) -> void:
	flip_spite(player.velocity)

func flip_spite(velocity: Vector2) -> void:
	if velocity.x > 0.0:
		flip_h = false
	if velocity.x < 0.0:
		flip_h = true
"

